---
import Layout from '../layouts/Layout.astro';

const faqs = [
	{
		q: 'Is TagSmith really free?',
		a: 'Yes. Every tag is generated on your own device from a hardcoded word list, so there is no server cost per generation and no reason to charge or limit usage.',
	},
	{
		q: 'Is anything I generate uploaded anywhere?',
		a: 'No. Tags are assembled locally in your browser. Nothing ever leaves your device.',
	},
	{
		q: 'What vibes are available?',
		a: 'Fantasy, Sci-Fi, Edgy, and Cute — each pulls from its own curated list of adjectives and nouns so the tags actually match the mood you want.',
	},
	{
		q: 'Can I add numbers or the xX...Xx style?',
		a: 'Yes. Toggle "Add numbers" for a two-digit suffix, and "Add xX…Xx decoration" for the classic wrapped-username look. Both are optional and can be combined.',
	},
	{
		q: 'Will two people ever get the exact same tag?',
		a: 'It is possible but unlikely — each vibe combines dozens of adjectives with dozens of nouns, plus optional numbers, for thousands of combinations. Click Generate again for a fresh one.',
	},
];
---

<Layout
	title="FAQ — TagSmith"
	description="Frequently asked questions about TagSmith's free, private, browser-based gamer tag generator."
	canonicalPath="/faq"
>
	<div class="mx-auto max-w-2xl">
		<h1 class="font-display text-3xl font-semibold tracking-tight text-[#2B2013]">
			Frequently Asked Questions
		</h1>
		<div class="mt-8 space-y-8">
			{
				faqs.map((item) => (
					<div class="rounded-xl border border-[#E8DFC8] bg-white p-5">
						<h2 class="font-display text-lg font-semibold text-[#2B2013]">{item.q}</h2>
						<p class="mt-2 text-[#5C4F3D]">{item.a}</p>
					</div>
				))
			}
		</div>
	</div>
</Layout>
