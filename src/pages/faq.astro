---
import Layout from '../layouts/Layout.astro';

const faqs = [
	{
		q: 'Is TagSmith really free?',
		a: 'Yes. Every tag is generated on your own device from a hardcoded word list, so there is no server cost per generation and no reason to charge or limit usage.',
	},
	{
		q: 'Is anything I generate uploaded anywhere?',
		a: 'No. Tags are assembled locally in your browser. Nothing ever leaves your device.',
	},
	{
		q: 'What vibes are available?',
		a: 'Fantasy, Sci-Fi, Edgy, and Cute, each pulls from its own curated list of adjectives and nouns so the tags actually match the mood you want.',
	},
	{
		q: 'Can I control the length and characters?',
		a: 'Yes. Toggle numbers and special characters on or off, add the classic xX…Xx wrapper, and drag the max-length slider so every tag fits under your platform username cap. Tags are re-rolled until they fit.',
	},
	{
		q: 'How do favorites work?',
		a: 'Click the star on any tag you like and it is saved to your device using localStorage. Your favorites stay put between visits and never touch a server. Clear them any time.',
	},
	{
		q: 'Will two people ever get the exact same tag?',
		a: 'It is possible but unlikely, each vibe combines dozens of adjectives with dozens of nouns, plus optional numbers and separators, for thousands of combinations. Click Generate again for a fresh one.',
	},
];
---

<Layout
	title="FAQ — TagSmith"
	description="Frequently asked questions about TagSmith's free, private, browser-based gamer tag generator."
	canonicalPath="/faq"
>
	<div>
		<p class="font-display text-sm font-bold uppercase tracking-[0.2em] text-[#c9982e]">
			Help
		</p>
		<h1 class="mt-4 font-display text-4xl font-extrabold tracking-tight text-[#221b10]">
			Frequently Asked Questions
		</h1>
		<div class="mt-8 space-y-5">
			{
				faqs.map((item) => (
					<div class="rounded-2xl border border-[#eae4d6] bg-[#faf8f3] p-6">
						<h2 class="font-display text-lg font-bold text-[#221b10]">{item.q}</h2>
						<p class="mt-2.5 text-[16px] leading-relaxed text-[#4a4234]">{item.a}</p>
					</div>
				))
			}
		</div>
	</div>
</Layout>
