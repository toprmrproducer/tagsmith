---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout
	title="About — TagSmith"
	description="TagSmith is a free, browser-based gamer tag generator. Learn how it works and why it's free."
	canonicalPath="/about"
>
	<div>
		<p class="font-display text-sm font-bold uppercase tracking-[0.2em] text-[#c9982e]">
			About
		</p>
		<h1 class="mt-4 font-display text-4xl font-extrabold tracking-tight text-[#221b10]">
			About TagSmith
		</h1>
		<div class="mt-7 space-y-5 text-[17px] leading-relaxed text-[#4a4234]">
			<p>
				TagSmith is a single-purpose tool for generating gamer tags,
				usernames, and Discord handles, entirely inside your web browser.
				Every tag is assembled on your device from hardcoded, curated word
				lists. Nothing you generate is ever uploaded to a server.
			</p>
			<p>
				Because there is no server-side processing, TagSmith can stay
				completely free with no account, no watermark, and no rate limits.
				The site is supported by on-page advertising.
			</p>
			<p>
				Pick a vibe (Fantasy, Sci-Fi, Edgy, or Cute), toggle numbers, special
				characters, and the classic <strong class="text-[#221b10]">xX&hellip;Xx</strong>
				decoration on or off, cap the length to fit any platform, and click
				Generate as many times as you like. Star the tags you love to keep
				them in your favorites list, which lives on your device between visits.
			</p>
		</div>

		<div class="mt-10 rounded-2xl border border-[#eae4d6] bg-[#faf8f3] p-6 sm:p-8">
			<h2 class="font-display text-xl font-bold text-[#221b10]">Ready to build a tag?</h2>
			<p class="mt-2 text-[15px] text-[#4a4234]">Jump back to the generator and roll a fresh handle.</p>
			<a
				href={base}
				class="mt-5 inline-block rounded-xl bg-[#c9982e] px-6 py-3 text-[15px] font-bold text-white transition hover:bg-[#b8860b]"
			>
				Open the generator
			</a>
		</div>
	</div>
</Layout>
