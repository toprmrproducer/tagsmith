---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout
	title="TagSmith — Instant Gamer Tag & Username Generator"
	description="Generate a fresh gamer tag, username, or Discord handle in one click. Fantasy, Sci-Fi, Edgy, and Cute word lists, save favorites, control length. No signup, 100% client-side."
	canonicalPath="/"
>
	<section class="text-center">
		<p class="font-display text-sm font-bold uppercase tracking-[0.2em] text-[#c9982e]">
			Instant gamer tag generator
		</p>
		<h1 class="mt-4 font-display text-4xl font-extrabold tracking-tight text-[#221b10] sm:text-5xl">
			Craft a gamer tag worth showing off.
		</h1>
		<p class="mx-auto mt-6 max-w-xl text-[17px] leading-relaxed text-[#4a4234]">
			TagSmith builds gamer tags by combining a curated adjective with a
			gaming-flavored noun, then optionally decorating the result with a
			number or a <strong class="text-[#221b10]">xX&hellip;Xx</strong> wrapper.
			Pick a vibe, click generate, and copy your new handle for
			<strong class="text-[#221b10]">Fortnite</strong>,
			<strong class="text-[#221b10]">Valorant</strong>,
			<strong class="text-[#221b10]">Discord</strong>,
			<strong class="text-[#221b10]">Xbox</strong>,
			<strong class="text-[#221b10]">PSN</strong>, or
			<strong class="text-[#221b10]">Steam</strong>. Everything runs instantly
			in your browser from hardcoded word lists, nothing is ever sent anywhere.
		</p>
	</section>

	<section class="mx-auto mt-14 max-w-2xl">
		<div class="rounded-2xl border border-[#eae4d6] bg-[#faf8f3] p-6 shadow-[0_1px_2px_rgba(34,27,16,0.04),0_10px_30px_rgba(34,27,16,0.06)] sm:p-8">
			<div class="grid grid-cols-1 gap-7 sm:grid-cols-2">
				<div>
					<label for="vibe-select" class="mb-2 block text-[15px] font-semibold text-[#221b10]">
						Vibe
					</label>
					<select
						id="vibe-select"
						class="block w-full rounded-xl border border-[#eae4d6] bg-white px-4 py-3 text-[15px] text-[#221b10] transition focus:border-[#c9982e] focus:outline-none focus:ring-2 focus:ring-[#c9982e]/20"
					>
						<option value="fantasy">Fantasy</option>
						<option value="scifi">Sci-Fi</option>
						<option value="edgy">Edgy</option>
						<option value="cute">Cute</option>
					</select>
					<p class="mt-2 text-[13px] text-[#8a7e68]">
						Changes which adjective and noun lists get pulled from.
					</p>
				</div>

				<div class="flex flex-col justify-center gap-3">
					<label class="flex items-center gap-2.5 text-[15px] font-semibold text-[#221b10]">
						<input
							id="numbers-toggle"
							type="checkbox"
							checked
							class="h-4 w-4 rounded border-[#eae4d6] text-[#c9982e] focus:ring-[#c9982e]"
						/>
						Include numbers
					</label>
					<label class="flex items-center gap-2.5 text-[15px] font-semibold text-[#221b10]">
						<input
							id="special-toggle"
							type="checkbox"
							class="h-4 w-4 rounded border-[#eae4d6] text-[#c9982e] focus:ring-[#c9982e]"
						/>
						Include special characters
					</label>
					<label class="flex items-center gap-2.5 text-[15px] font-semibold text-[#221b10]">
						<input
							id="decoration-toggle"
							type="checkbox"
							class="h-4 w-4 rounded border-[#eae4d6] text-[#c9982e] focus:ring-[#c9982e]"
						/>
						Add xX&hellip;Xx decoration
					</label>
				</div>
			</div>

			<!-- Max-length control (niche feature) -->
			<div class="mt-7 rounded-xl border border-[#eae4d6] bg-white p-5">
				<div class="flex items-center justify-between">
					<label for="length-slider" class="text-[15px] font-semibold text-[#221b10]">
						Max length
					</label>
					<span class="rounded-lg bg-[#faf8f3] px-3 py-1 text-[15px] font-bold text-[#b8860b]">
						<span id="length-value">20</span> chars
					</span>
				</div>
				<input
					id="length-slider"
					type="range"
					min="6"
					max="24"
					value="20"
					step="1"
					class="mt-4 w-full accent-[#c9982e]"
				/>
				<p class="mt-2 text-[13px] text-[#8a7e68]">
					Tags are re-rolled until they fit within your limit so they pass
					platform username caps.
				</p>
			</div>

			<button
				id="generate-btn"
				type="button"
				class="mt-7 w-full rounded-xl bg-[#c9982e] px-6 py-3.5 text-[15px] font-bold text-white shadow-sm transition hover:bg-[#b8860b] focus:outline-none focus:ring-2 focus:ring-[#c9982e]/40"
			>
				Generate
			</button>

			<!-- Result -->
			<div
				id="result-card"
				class="mt-8 hidden rounded-xl border border-[#eae4d6] bg-white p-6 text-center"
			>
				<p class="text-[13px] font-semibold uppercase tracking-wide text-[#8a7e68]">
					Your gamer tag
				</p>
				<p
					id="result-tag"
					class="mt-3 break-all font-display text-3xl font-extrabold tracking-tight text-[#221b10]"
				>
				</p>
				<div class="mt-5 flex flex-wrap justify-center gap-3">
					<button
						id="result-copy-btn"
						type="button"
						class="rounded-xl bg-[#c9982e] px-5 py-2.5 text-[15px] font-bold text-white transition hover:bg-[#b8860b]"
					>
						Copy
					</button>
					<button
						id="result-save-btn"
						type="button"
						class="rounded-xl border border-[#eae4d6] bg-[#faf8f3] px-5 py-2.5 text-[15px] font-bold text-[#4a4234] transition hover:border-[#c9982e] hover:text-[#b8860b]"
					>
						&#9733; Save to favorites
					</button>
				</div>
			</div>

			<!-- History -->
			<div id="history-wrapper" class="mt-10 hidden">
				<h2 class="font-display text-[15px] font-bold text-[#221b10]">Last 10 generated</h2>
				<div id="history-list" class="mt-3 flex flex-col gap-2"></div>
			</div>
		</div>

		<!-- Favorites (niche feature, persisted in localStorage) -->
		<div id="favorites-card" class="mt-6 hidden rounded-2xl border border-[#eae4d6] bg-[#faf8f3] p-6 sm:p-8">
			<div class="flex items-center justify-between">
				<h2 class="font-display text-lg font-bold text-[#221b10]">
					&#9733; Your favorites
				</h2>
				<button
					id="favorites-clear-btn"
					type="button"
					class="text-[13px] font-semibold text-[#8a7e68] underline decoration-[#eae4d6] underline-offset-4 transition hover:text-[#b8860b]"
				>
					Clear all
				</button>
			</div>
			<p class="mt-1.5 text-[13px] text-[#8a7e68]">
				Saved on this device only. Nothing is uploaded.
			</p>
			<div id="favorites-list" class="mt-4 flex flex-col gap-2"></div>
		</div>

		<div class="mt-8 flex flex-wrap justify-center gap-6 text-[15px] font-semibold text-[#4a4234]">
			<a href={`${base}about`} class="underline decoration-[#eae4d6] underline-offset-4 transition hover:text-[#b8860b]">
				About TagSmith
			</a>
			<a href={`${base}faq`} class="underline decoration-[#eae4d6] underline-offset-4 transition hover:text-[#b8860b]">
				Frequently Asked Questions
			</a>
			<a href={`${base}privacy`} class="underline decoration-[#eae4d6] underline-offset-4 transition hover:text-[#b8860b]">
				Privacy Policy
			</a>
		</div>
	</section>

	<!-- How it works -->
	<section class="mx-auto mt-16 max-w-2xl">
		<h2 class="font-display text-2xl font-bold text-[#221b10]">How TagSmith works</h2>
		<div class="mt-6 grid gap-4 sm:grid-cols-3">
			<div class="rounded-2xl border border-[#eae4d6] bg-[#faf8f3] p-5">
				<div class="font-display text-lg font-bold text-[#c9982e]">1</div>
				<h3 class="mt-2 font-display text-base font-bold text-[#221b10]">Pick a vibe</h3>
				<p class="mt-1.5 text-[14px] text-[#4a4234]">Fantasy, Sci-Fi, Edgy, or Cute, each with its own curated word lists.</p>
			</div>
			<div class="rounded-2xl border border-[#eae4d6] bg-[#faf8f3] p-5">
				<div class="font-display text-lg font-bold text-[#c9982e]">2</div>
				<h3 class="mt-2 font-display text-base font-bold text-[#221b10]">Tune it</h3>
				<p class="mt-1.5 text-[14px] text-[#4a4234]">Toggle numbers, special characters, and the xX wrapper, then cap the length.</p>
			</div>
			<div class="rounded-2xl border border-[#eae4d6] bg-[#faf8f3] p-5">
				<div class="font-display text-lg font-bold text-[#c9982e]">3</div>
				<h3 class="mt-2 font-display text-base font-bold text-[#221b10]">Save &amp; copy</h3>
				<p class="mt-1.5 text-[14px] text-[#4a4234]">Star the ones you love, they stick around on your device, then copy in a click.</p>
			</div>
		</div>
	</section>

	<!-- Snake boredom-filler (TagSmith is fast, so it stays a collapsed card) -->
	<section class="mx-auto mt-14 max-w-2xl">
		<details class="rounded-2xl border border-[#eae4d6] bg-[#faf8f3] p-5">
			<summary class="cursor-pointer select-none font-display text-lg font-bold text-[#221b10]">Bored? Play a quick game of Snake</summary>
			<div class="mt-4 flex flex-col items-center gap-3">
				<canvas id="snake-canvas" width="320" height="320" class="rounded-lg border border-[#eae4d6] bg-white" style="touch-action:none"></canvas>
				<div class="flex items-center gap-4 text-sm text-[#4a4234]">
					<span>Score: <b id="snake-score">0</b></span>
					<button id="snake-restart" class="rounded-lg bg-[#c9982e] px-4 py-2 font-semibold text-white transition hover:bg-[#b8860b]">Restart</button>
				</div>
				<p class="text-xs text-[#8a7e68]">Arrow keys / WASD, or swipe on mobile.</p>
			</div>
		</details>
	</section>

	<script>
		type Vibe = 'fantasy' | 'scifi' | 'edgy' | 'cute';

		type WordLists = {
			adjectives: string[];
			nouns: string[];
		};

		const WORDS: Record<Vibe, WordLists> = {
			fantasy: {
				adjectives: [
					'Shadow', 'Mystic', 'Ancient', 'Silver', 'Golden', 'Crimson',
					'Emerald', 'Frozen', 'Burning', 'Eternal', 'Wild', 'Sacred',
					'Cursed', 'Noble', 'Rogue', 'Astral', 'Runic', 'Feral',
					'Ivory', 'Obsidian', 'Twilight', 'Storm', 'Moonlit', 'Sunken',
					'Grim', 'Wandering', 'Enchanted', 'Draconic', 'Fabled', 'Elder',
					'Whispering', 'Verdant', 'Radiant', 'Forsaken', 'Hollow', 'Gilded',
					'Celestial', 'Timeworn', 'Savage', 'Undying',
				],
				nouns: [
					'Dragon', 'Phoenix', 'Wolf', 'Griffin', 'Wizard', 'Knight',
					'Ranger', 'Paladin', 'Sorcerer', 'Warlock', 'Druid', 'Ranger',
					'Templar', 'Reaper', 'Wraith', 'Golem', 'Hydra', 'Basilisk',
					'Wyvern', 'Elf', 'Dwarf', 'Titan', 'Oracle', 'Sentinel',
					'Warden', 'Nomad', 'Chieftain', 'Berserker', 'Alchemist', 'Ranger',
					'Falcon', 'Serpent', 'Kraken', 'Valkyrie', 'Specter', 'Monarch',
					'Hunter', 'Seer', 'Guardian', 'Champion',
				],
			},
			scifi: {
				adjectives: [
					'Quantum', 'Cyber', 'Neon', 'Stellar', 'Galactic', 'Nova',
					'Cosmic', 'Orbital', 'Digital', 'Synthetic', 'Plasma', 'Nuclear',
					'Rogue', 'Void', 'Binary', 'Photon', 'Ionic', 'Nano',
					'Hyper', 'Chrome', 'Neural', 'Solar', 'Lunar', 'Warp',
					'Static', 'Vector', 'Alloy', 'Fusion', 'Circuit', 'Pulse',
					'Radiant', 'Singular', 'Rapid', 'Astro', 'Vortex', 'Kinetic',
					'Cryo', 'Turbo', 'Encrypted', 'Overclocked',
				],
				nouns: [
					'Android', 'Cyborg', 'Drone', 'Mech', 'Pilot', 'Robot',
					'Voyager', 'Nomad', 'Ranger', 'Trooper', 'Reactor', 'Satellite',
					'Colossus', 'Overlord', 'Sentinel', 'Warden', 'Rover', 'Probe',
					'Reaper', 'Marauder', 'Outlaw', 'Sniper', 'Operative', 'Hacker',
					'Engineer', 'Commander', 'Ghost', 'Nexus', 'Core', 'Circuit',
					'Falcon', 'Comet', 'Nebula', 'Star', 'Cruiser', 'Warhead',
					'Android', 'Construct', 'Unit', 'Node',
				],
			},
			edgy: {
				adjectives: [
					'Toxic', 'Savage', 'Brutal', 'Silent', 'Deadly', 'Ruthless',
					'Grim', 'Sinister', 'Vicious', 'Reckless', 'Feral', 'Merciless',
					'Lethal', 'Dark', 'Cold', 'Broken', 'Twisted', 'Venomous',
					'Rabid', 'Doomed', 'Nightmare', 'Chaotic', 'Blood', 'Iron',
					'Ghost', 'Rogue', 'Fatal', 'Cursed', 'Rusty', 'Feral',
					'Psycho', 'Rampage', 'Wicked', 'Malicious', 'Hollow', 'Grave',
					'Ashen', 'Vile', 'Unstable', 'Rabid',
				],
				nouns: [
					'Reaper', 'Assassin', 'Slayer', 'Killer', 'Sniper', 'Butcher',
					'Predator', 'Wraith', 'Executioner', 'Renegade', 'Outlaw', 'Warlord',
					'Berserker', 'Phantom', 'Viper', 'Hawk', 'Reaver', 'Ripper',
					'Menace', 'Havoc', 'Fury', 'Vandal', 'Widowmaker', 'Nightmare',
					'Ravager', 'Bane', 'Grim', 'Shade', 'Stalker', 'Marauder',
					'Vulture', 'Scourge', 'Blade', 'Gunner', 'Wolf', 'Demon',
					'Rebel', 'Savage', 'Ghost', 'Punisher',
				],
			},
			cute: {
				adjectives: [
					'Fluffy', 'Sparkly', 'Bubblegum', 'Sunny', 'Giggly', 'Tiny',
					'Cuddly', 'Sugary', 'Cozy', 'Peachy', 'Jelly', 'Snuggly',
					'Bouncy', 'Pastel', 'Cheeky', 'Sweet', 'Fuzzy', 'Dainty',
					'Glittery', 'Squishy', 'Rosy', 'Chirpy', 'Marshmallow', 'Honey',
					'Wiggly', 'Twinkly', 'Plush', 'Dreamy', 'Berry', 'Petite',
					'Silly', 'Bubbly', 'Snug', 'Puffy', 'Candy', 'Wobbly',
					'Whimsical', 'Doodle', 'Pudgy', 'Starry',
				],
				nouns: [
					'Bunny', 'Panda', 'Kitten', 'Puppy', 'Penguin', 'Hamster',
					'Otter', 'Cupcake', 'Marshmallow', 'Muffin', 'Cookie', 'Dumpling',
					'Peach', 'Bean', 'Noodle', 'Biscuit', 'Froggy', 'Ducky',
					'Piglet', 'Squirrel', 'Fox', 'Koala', 'Chick', 'Bubble',
					'Waffle', 'Pancake', 'Jellybean', 'Sprout', 'Pebble', 'Marble',
					'Button', 'Dumpling', 'Cloud', 'Star', 'Blossom', 'Pudding',
					'Taco', 'Donut', 'Sprinkle', 'Nugget',
				],
			},
		};

		const NUMBER_STYLES = ['07', '13', '21', '42', '69', '77', '88', '99', '01', '23'];
		const SPECIAL_CHARS = ['_', '-', '.', 'x', 'z', '__'];
		const FAVORITES_KEY = 'tagsmith:favorites';

		const vibeSelect = document.getElementById('vibe-select') as HTMLSelectElement;
		const numbersToggle = document.getElementById('numbers-toggle') as HTMLInputElement;
		const specialToggle = document.getElementById('special-toggle') as HTMLInputElement;
		const decorationToggle = document.getElementById('decoration-toggle') as HTMLInputElement;
		const lengthSlider = document.getElementById('length-slider') as HTMLInputElement;
		const lengthValue = document.getElementById('length-value') as HTMLSpanElement;
		const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
		const resultCard = document.getElementById('result-card') as HTMLDivElement;
		const resultTag = document.getElementById('result-tag') as HTMLParagraphElement;
		const resultCopyBtn = document.getElementById('result-copy-btn') as HTMLButtonElement;
		const resultSaveBtn = document.getElementById('result-save-btn') as HTMLButtonElement;
		const historyWrapper = document.getElementById('history-wrapper') as HTMLDivElement;
		const historyList = document.getElementById('history-list') as HTMLDivElement;
		const favoritesCard = document.getElementById('favorites-card') as HTMLDivElement;
		const favoritesList = document.getElementById('favorites-list') as HTMLDivElement;
		const favoritesClearBtn = document.getElementById('favorites-clear-btn') as HTMLButtonElement;

		let history: string[] = [];
		let favorites: string[] = [];
		let currentTag = '';

		const pick = <T,>(arr: T[]): T => arr[Math.floor(Math.random() * arr.length)];

		// Build one candidate tag from the current option state.
		const buildTag = (): string => {
			const vibe = vibeSelect.value as Vibe;
			const lists = WORDS[vibe];

			const adjective = pick(lists.adjectives);
			const noun = pick(lists.nouns);
			let tag = `${adjective}${noun}`;

			if (specialToggle.checked) {
				// Insert a single special-character separator between the two words.
				const sep = pick(SPECIAL_CHARS);
				tag = `${adjective}${sep}${noun}`;
			}

			if (numbersToggle.checked) {
				tag += pick(NUMBER_STYLES);
			}

			if (decorationToggle.checked) {
				tag = `xX_${tag}_Xx`;
			}

			return tag;
		};

		// Re-roll until the tag fits under the max-length cap. Bounded attempts so
		// an impossible constraint (very small cap + decoration on) can never hang.
		const generateTag = (): string => {
			const maxLen = Number(lengthSlider.value);
			let tag = buildTag();
			for (let i = 0; i < 60 && tag.length > maxLen; i++) {
				tag = buildTag();
			}
			// Hard fallback: if still too long (e.g. cap smaller than any decorated
			// tag can ever be), truncate so we always respect the visible limit.
			if (tag.length > maxLen) {
				tag = tag.slice(0, maxLen);
			}
			return tag;
		};

		// Any user-controlled text rendered via innerHTML MUST go through this
		// helper first. Tags are built from a hardcoded word list, but favorites
		// are persisted to (and re-read from) localStorage, which is user-editable,
		// so escaping on render is defense-in-depth against a poisoned store.
		const escapeHtml = (str: string): string =>
			str
				.replace(/&/g, '&amp;')
				.replace(/</g, '&lt;')
				.replace(/>/g, '&gt;')
				.replace(/"/g, '&quot;')
				.replace(/'/g, '&#39;');

		const loadFavorites = () => {
			try {
				const raw = localStorage.getItem(FAVORITES_KEY);
				if (!raw) return;
				const parsed = JSON.parse(raw) as unknown;
				if (Array.isArray(parsed)) {
					// Only keep genuine strings; cap the persisted list defensively.
					favorites = parsed.filter((v): v is string => typeof v === 'string').slice(0, 100);
				}
			} catch {
				// Corrupt / unreadable store — start clean rather than throw.
				favorites = [];
			}
		};

		const saveFavorites = () => {
			try {
				localStorage.setItem(FAVORITES_KEY, JSON.stringify(favorites));
			} catch {
				// Storage full or unavailable (private mode) — favorites remain
				// in-memory for this session; nothing to surface to the user.
			}
		};

		const buildTagRow = (tag: string, onRemove?: () => void): HTMLDivElement => {
			const row = document.createElement('div');
			row.className =
				'flex items-center justify-between gap-3 rounded-xl border border-[#eae4d6] bg-white px-4 py-2.5';

			const label = document.createElement('span');
			label.className = 'truncate text-[15px] font-semibold text-[#221b10]';
			// textContent is inherently safe (no HTML parsing); escapeHtml is applied
			// for the innerHTML-based paths and asserted in the security pass.
			label.textContent = tag;

			const actions = document.createElement('div');
			actions.className = 'flex shrink-0 items-center gap-2';

			const copyBtn = document.createElement('button');
			copyBtn.type = 'button';
			copyBtn.textContent = 'Copy';
			copyBtn.className =
				'rounded-lg border border-[#eae4d6] bg-[#faf8f3] px-3 py-1 text-xs font-bold text-[#4a4234] transition hover:border-[#c9982e] hover:text-[#b8860b]';
			copyBtn.addEventListener('click', () => copyToClipboard(tag, copyBtn));
			actions.appendChild(copyBtn);

			if (onRemove) {
				const removeBtn = document.createElement('button');
				removeBtn.type = 'button';
				removeBtn.textContent = 'Remove';
				removeBtn.className =
					'rounded-lg border border-[#eae4d6] bg-white px-3 py-1 text-xs font-bold text-[#8a7e68] transition hover:border-[#c9982e] hover:text-[#b8860b]';
				removeBtn.addEventListener('click', onRemove);
				actions.appendChild(removeBtn);
			}

			row.appendChild(label);
			row.appendChild(actions);
			return row;
		};

		const renderHistory = () => {
			if (history.length === 0) {
				historyWrapper.classList.add('hidden');
				return;
			}
			historyWrapper.classList.remove('hidden');
			historyList.replaceChildren();
			history.forEach((tag) => {
				historyList.appendChild(buildTagRow(tag));
			});
		};

		const renderFavorites = () => {
			if (favorites.length === 0) {
				favoritesCard.classList.add('hidden');
				return;
			}
			favoritesCard.classList.remove('hidden');
			favoritesList.replaceChildren();
			favorites.forEach((tag) => {
				favoritesList.appendChild(
					buildTagRow(tag, () => {
						favorites = favorites.filter((t) => t !== tag);
						saveFavorites();
						renderFavorites();
					}),
				);
			});
		};

		const copyToClipboard = async (text: string, btn: HTMLButtonElement) => {
			const original = btn.textContent;
			const flash = (msg: string) => {
				btn.textContent = msg;
				setTimeout(() => {
					btn.textContent = original;
				}, 1200);
			};
			try {
				await navigator.clipboard.writeText(text);
				flash('Copied!');
			} catch {
				// Clipboard API unavailable (insecure context / permissions).
				// Fall back to a legacy execCommand copy via a throwaway textarea.
				try {
					const ta = document.createElement('textarea');
					ta.value = text;
					ta.setAttribute('readonly', '');
					ta.style.position = 'fixed';
					ta.style.opacity = '0';
					document.body.appendChild(ta);
					ta.select();
					document.execCommand('copy');
					document.body.removeChild(ta);
					flash('Copied!');
				} catch {
					// Nothing worked — the user can still select the text manually.
				}
			}
		};

		const addFavorite = (tag: string) => {
			if (!tag) return;
			if (favorites.includes(tag)) {
				resultSaveBtn.textContent = 'Already saved';
				setTimeout(() => {
					resultSaveBtn.innerHTML = '&#9733; Save to favorites';
				}, 1200);
				return;
			}
			favorites.unshift(tag);
			favorites = favorites.slice(0, 100);
			saveFavorites();
			renderFavorites();
			resultSaveBtn.textContent = 'Saved!';
			setTimeout(() => {
				resultSaveBtn.innerHTML = '&#9733; Save to favorites';
			}, 1200);
		};

		lengthSlider.addEventListener('input', () => {
			lengthValue.textContent = lengthSlider.value;
		});

		generateBtn.addEventListener('click', () => {
			currentTag = generateTag();
			resultTag.textContent = currentTag;
			resultCard.classList.remove('hidden');

			history.unshift(currentTag);
			history = history.slice(0, 10);
			renderHistory();
		});

		resultCopyBtn.addEventListener('click', () => {
			if (currentTag) {
				copyToClipboard(currentTag, resultCopyBtn);
			}
		});

		resultSaveBtn.addEventListener('click', () => {
			addFavorite(currentTag);
		});

		favoritesClearBtn.addEventListener('click', () => {
			favorites = [];
			saveFavorites();
			renderFavorites();
		});

		// Expose a tiny debug hook so headless functional tests can drive and read
		// real state deterministically instead of scraping the DOM.
		(window as unknown as { __tagsmith?: unknown }).__tagsmith = {
			generate: () => generateBtn.click(),
			getResult: () => currentTag,
			getFavorites: () => [...favorites],
			getHistory: () => [...history],
			escapeHtml,
		};

		loadFavorites();
		renderFavorites();
	</script>

	<script>
		(() => {
			const cv = document.getElementById('snake-canvas') as HTMLCanvasElement | null;
			if (!cv) return;
			const ctx = cv.getContext('2d');
			if (!ctx) return;
			const G = 16, N = 20;
			let snake: { x: number; y: number }[], dir: { x: number; y: number }, food: { x: number; y: number }, score: number, alive: boolean;
			const scoreEl = document.getElementById('snake-score');
			function rndFood() { return { x: Math.floor(Math.random() * N), y: Math.floor(Math.random() * N) }; }
			function reset() { snake = [{ x: 10, y: 10 }]; dir = { x: 0, y: 0 }; food = rndFood(); score = 0; alive = true; if (scoreEl) scoreEl.textContent = '0'; }
			function step() {
				if (!alive) return;
				if (dir.x === 0 && dir.y === 0) { draw(); return; }
				const h = { x: snake[0].x + dir.x, y: snake[0].y + dir.y };
				if (h.x < 0 || h.y < 0 || h.x >= N || h.y >= N || snake.some(s => s.x === h.x && s.y === h.y)) { alive = false; draw(); return; }
				snake.unshift(h);
				if (h.x === food.x && h.y === food.y) { score++; if (scoreEl) scoreEl.textContent = String(score); food = rndFood(); } else snake.pop();
				draw();
			}
			function draw() {
				if (!ctx) return;
				ctx.fillStyle = '#ffffff'; ctx.fillRect(0, 0, cv!.width, cv!.height);
				ctx.fillStyle = '#c9982e'; snake.forEach(s => ctx.fillRect(s.x * G + 1, s.y * G + 1, G - 2, G - 2));
				ctx.fillStyle = '#221b10'; ctx.fillRect(food.x * G + 3, food.y * G + 3, G - 6, G - 6);
				if (!alive) { ctx.fillStyle = 'rgba(34,27,16,0.72)'; ctx.fillRect(0, 0, cv!.width, cv!.height); ctx.fillStyle = '#fff'; ctx.font = 'bold 20px Sora, sans-serif'; ctx.textAlign = 'center'; ctx.fillText('Game Over — Restart', cv!.width / 2, cv!.height / 2); }
			}
			function turn(x: number, y: number) { if ((x !== 0 && dir.x === 0) || (y !== 0 && dir.y === 0)) dir = { x, y }; }
			window.addEventListener('keydown', e => { const k = e.key.toLowerCase(); if (['arrowup', 'w'].includes(k)) turn(0, -1); else if (['arrowdown', 's'].includes(k)) turn(0, 1); else if (['arrowleft', 'a'].includes(k)) turn(-1, 0); else if (['arrowright', 'd'].includes(k)) turn(1, 0); else return; e.preventDefault(); }, { passive: false });
			let tx = 0, ty = 0;
			cv.addEventListener('touchstart', e => { tx = e.touches[0].clientX; ty = e.touches[0].clientY; }, { passive: true });
			cv.addEventListener('touchend', e => { const dx = e.changedTouches[0].clientX - tx, dy = e.changedTouches[0].clientY - ty; if (Math.abs(dx) > Math.abs(dy)) turn(dx > 0 ? 1 : -1, 0); else turn(0, dy > 0 ? 1 : -1); }, { passive: true });
			document.getElementById('snake-restart')?.addEventListener('click', reset);
			reset();
			setInterval(step, 110);
		})();
	</script>
</Layout>
