---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout
	title="Page Not Found — TagSmith"
	description="This page could not be found."
	canonicalPath="/404"
>
	<div class="py-20 text-center">
		<p class="font-display text-sm font-bold uppercase tracking-[0.2em] text-[#c9982e]">
			Error 404
		</p>
		<h1 class="mt-4 font-display text-5xl font-extrabold text-[#221b10]">Page not found</h1>
		<p class="mx-auto mt-5 max-w-md text-[17px] leading-relaxed text-[#4a4234]">
			That page doesn't exist. Head back to the generator and craft a fresh
			gamer tag instead.
		</p>
		<a
			href={base}
			class="mt-8 inline-block rounded-xl bg-[#c9982e] px-6 py-3 text-[15px] font-bold text-white transition hover:bg-[#b8860b]"
		>
			Back to the homepage
		</a>
	</div>
</Layout>
